# Copy this file to .env for local development (npm run dev reads .env
# automatically via Vite). In production, set these as environment
# variables on the Netlify site instead (Site settings -> Environment
# variables, or `netlify env:set KEY value`).
#
# CLIENT-SAFE vars (must be prefixed VITE_ to be readable by the browser
# bundle -- Vite only exposes VITE_-prefixed vars to client code):

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# ---------------------------------------------------------------------------
# SERVER-ONLY vars, used by netlify/functions/*.ts. NEVER prefix these with
# VITE_ -- doing so would bundle them into the public client JS. These are
# only ever read inside a Netlify Function's Node process, never sent to
# the browser.

# Supabase project settings -> API -> service_role key (NOT the anon key).
# Bypasses Row Level Security -- functions use it to write enrollments and
# read gated lesson content after checking entitlement themselves.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Supabase project settings -> API -> JWT Secret. Used to verify a user's
# access token locally (no network round trip) in netlify/functions/_shared/verifyJwt.ts.
SUPABASE_JWT_SECRET=your-jwt-secret

# Stripe dashboard -> Developers -> API keys (use the *secret* key, sk_...).
# Test mode (sk_test_...) while you're setting this up; switch to live
# (sk_live_...) only once you've verified the full flow end to end.
STRIPE_SECRET_KEY=sk_test_...

# Stripe dashboard -> Developers -> Webhooks -> your endpoint -> Signing secret.
# Required to verify that a webhook POST genuinely came from Stripe before
# granting any enrollment.
STRIPE_WEBHOOK_SECRET=whsec_...
