      "id": "file:tests/test_nlme.py",
      "type": "file",
      "name": "test_nlme.py",
      "filePath": "tests/test_nlme.py",
      "summary": "Comprehensive unit tests for the NLME estimation engine: simulates synthetic populations with known parameters and verifies FOCE-I and SAEM recover theta/omega/sigma, plus covariate models, SCM selection, parameter uncertainty (RSE), and M3 BLQ censored-likelihood handling.",
      "tags": ["test", "nlme", "parameter-recovery", "pharmacometrics", "scm"],
      "complexity": "complex",
      "languageNotes": "Heavy use of pytest fixtures (session-scoped synthetic populations) and pytest.approx tolerance-based parameter-recovery assertions; numpy RNG seeding makes simulations deterministic."
    },
