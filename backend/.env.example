# PharmAgent backend configuration (copy to .env). All vars are PHARMAGENT_*.
# The app runs fully without any of these — MockLLM (keyless, deterministic) is
# the default and the whole test suite is keyless.

# --- LLM (optional; MockLLM used when no key) ---
# PHARMAGENT_ANTHROPIC_API_KEY=sk-ant-...
# PHARMAGENT_MODEL=claude-opus-4-8
# PHARMAGENT_MAX_TOKENS=2048
# PHARMAGENT_USE_MOCK_LLM=false

# --- Storage ---
# PHARMAGENT_DATA_DIR=data
# PHARMAGENT_DB_PATH=pharmagent.db

# --- Auth (unset = open dev mode; set = bearer token required on all sessions) ---
# PHARMAGENT_API_TOKEN=change-me-to-a-long-random-secret

# --- CORS: default ['*']; set to your UI origin(s) in production ---
# PHARMAGENT_CORS_ORIGINS=["https://app.example.com"]

# --- Branding ---
# PHARMAGENT_APP_NAME=PharmAgent
# PHARMAGENT_ORG_NAME=PmatricsAI
